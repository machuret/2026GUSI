# Supabase — get these from your Supabase project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Vimeo — https://developer.vimeo.com/apps
VIMEO_ACCESS_TOKEN=your-personal-access-token
VIMEO_CLIENT_ID=your-client-id
VIMEO_CLIENT_SECRET=your-client-secret
